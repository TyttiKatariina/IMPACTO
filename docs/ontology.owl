    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#ServiceRelatedConsequence">
        <rdfs:label xml:lang="en">Service Related Consequence</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Impact"/>
        <skos:definition xml:lang="en">A consequence that affects an individual&apos;s or organisation&apos;s access to or participation in a service</skos:definition>
        <skos:prefLabel xml:lang="en">Service Related Consequence</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Parent term for service-related consequences</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#ai-AutomaticObjectRecognition">
        <rdfs:label xml:lang="en">Automatic Object Recognition</rdfs:label>
        <skos:definition xml:lang="en">The use of an AI system capable of automatic object recognition</skos:definition>
        <skos:prefLabel xml:lang="en">Automatic Object Recognition</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#ai-FacialRecognition">
        <rdfs:label xml:lang="en">Facial Recognition</rdfs:label>
        <skos:definition xml:lang="en">The use of an AI system capable of facial recognition</skos:definition>
        <skos:prefLabel xml:lang="en">Facial Recognition</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#ai-ObjectIsolation">
        <rdfs:label xml:lang="en">Object Isolation</rdfs:label>
        <skos:definition xml:lang="en">The use of an AI system capable of isolating objects</skos:definition>
        <skos:prefLabel xml:lang="en">Object Isolation</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#ai-UseOfAI">
        <rdfs:label xml:lang="en">Use Of AI</rdfs:label>
        <skos:definition xml:lang="en">The use of an AI system in processing of personal data</skos:definition>
        <skos:prefLabel xml:lang="en">Use Of AI</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-Automated">
        <rdfs:label xml:lang="en">Automated</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ProcessingContext"/>
        <skos:definition xml:lang="en">Processing context indicating that automation is involved and parent concept for all automation-related processing contexts</skos:definition>
        <skos:prefLabel xml:lang="en">Automated</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-CentralisedLocation">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceDE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSI"/>
        <rdfs:label xml:lang="en">Centralised Location</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationFixture"/>
        <skos:definition xml:lang="en">A physical or digital point where data is collected and aggregated from multiple sources, typically involving centralised sensors or mobile-based systems for large-scale monitoring or control</skos:definition>
        <skos:notation>C62</skos:notation>
        <skos:prefLabel xml:lang="en">Centralised Location</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-ClassificationOfIndividuals">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">Classification Of Individuals</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ProcessingContext"/>
        <skos:definition xml:lang="en">Processing that evaluates, ranks, or categorises natural persons, often based on behavioural, demographic, or personal data</skos:definition>
        <skos:notation>C48</skos:notation>
        <skos:prefLabel xml:lang="en">Classification Of Individuals</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Phrasing follows Article 29 Data Protection Working Party and EDPB guidelines</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-HistoricResearch">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSK"/>
        <rdfs:label xml:lang="en">Historical Research</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ResearchAndDevelopment"/>
        <skos:definition xml:lang="en">The processing of personal data for scientific or historical research purposes, conducted without the data subject&apos;s consent, and in conjunction with at least one of the legal criteria under the GDPR, such as being necessary for a task carried out in the public interest</skos:definition>
        <skos:notation>C30</skos:notation>
        <skos:prefLabel xml:lang="en">Historical Research</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-Inspection">
        <rdfs:label xml:lang="en">Inspection</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ProcessingContext"/>
        <skos:definition xml:lang="en">A processing context where personal data is used as part of an evaluative or investigative activity or purpose</skos:definition>
        <skos:prefLabel xml:lang="en">Inspection</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-LabourBrokeringService">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
        <rdfs:label xml:lang="en">Labour Brokering Service</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#HumanResourceManagement"/>
        <skos:definition xml:lang="en">Service that facilitates labour provision through a brokering process, including matching workers with jobs or facilitating labour based on demand</skos:definition>
        <skos:notation>C105</skos:notation>
        <skos:prefLabel xml:lang="en">Labour Brokering Service</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-Monitoring">
        <skos:definition xml:lang="en">A purpose involving the monitoring of individuals</skos:definition>
        <skos:prefLabel xml:lang="en">Monitoring</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-MonitoringIndividuals">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Monitoring Individuals</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ProcessingContext"/>
        <skos:definition xml:lang="en">Monitoring of humans (as individuals or as groups) which includes a systematic observation or surveillance of behaviour, movements, or activities</skos:definition>
        <skos:notation>C5, C43, C46, C53, C55, C61, C76, C87, C97</skos:notation>
        <skos:prefLabel xml:lang="en">Monitoring Individuals</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Proposed as addition to dpv: — differs from existing dpv:Monitor (which monitors data for criteria) by focusing specifically on monitoring of data subjects themselves</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-NonDataSubjectDataSource">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCZ"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceDE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceES"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLT"/>
        <rdfs:label xml:lang="en">Non Data Subject Data Source</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#DataSource"/>
        <skos:definition xml:lang="en">Personal data obtained from a third party or another source rather than directly from the individual concerned, especially in cases where informing the data subject would be difficult or impossible, such as in law enforcement, research, or archival processing</skos:definition>
        <skos:notation>C25</skos:notation>
        <skos:prefLabel xml:lang="en">Non Data Subject Data Source</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Existing non-data subject sources in DPV should be moved below this concept</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-Predict">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEDPB"/>
        <rdfs:label xml:lang="en">Predict</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Infer"/>
        <skos:definition xml:lang="en">To anticipate or forecast aspects of an individual&apos;s behaviour, characteristics, or future actions</skos:definition>
        <skos:notation>C14, C37, C73</skos:notation>
        <skos:prefLabel xml:lang="en">Predict</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-PreventativeProtectionOfPersons">
        <rdfs:label xml:lang="en">Preventative Protection Of Persons</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#EnforceSecurity"/>
        <skos:definition xml:lang="en">Processing carried out for the purpose of preventing harm or protecting individuals before an incident occurs</skos:definition>
        <skos:prefLabel xml:lang="en">Preventative Protection Of Persons</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-PreventativeProtectionOfProperty">
        <rdfs:label xml:lang="en">Preventative Protection Of Property</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#EnforceSecurity"/>
        <skos:definition xml:lang="en">Processing carried out for the purpose of preventing loss or damage to property before an incident occurs</skos:definition>
        <skos:prefLabel xml:lang="en">Preventative Protection Of Property</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-PrivateUtilityProvider">
        <rdfs:label xml:lang="en">Private Utility Provider</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#dpv-UtilityProvider"/>
        <skos:definition xml:lang="en">A private organisation providing utilities</skos:definition>
        <skos:prefLabel xml:lang="en">Private Utility Provider</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-PublicUtilityProvider">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceRO"/>
        <rdfs:label xml:lang="en">Public Utility Provider</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#dpv-UtilityProvider"/>
        <skos:definition xml:lang="en">A public organisation providing utilities</skos:definition>
        <skos:notation>C23</skos:notation>
        <skos:prefLabel xml:lang="en">Public Utility Provider</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-Tracking">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLI"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <rdfs:label xml:lang="en">Tracking</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Use"/>
        <skos:definition xml:lang="en">The use of data to follow or track something across contexts</skos:definition>
        <skos:notation>C58</skos:notation>
        <skos:prefLabel xml:lang="en">Tracking</skos:prefLabel>
        <skos:scopeNote xml:lang="en">While generalised to enable tracking of activities and events, this also encompasses tracking of individuals across websites, apps, devices, and other forms which can constitute systematic monitoring and surveillance</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-UnknownDataSource">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIE"/>
        <rdfs:label xml:lang="en">Unknown Data Source</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#DataSource"/>
        <skos:definition xml:lang="en">The origin of personal data cannot be determined or is not known</skos:definition>
        <skos:notation>C94</skos:notation>
        <skos:prefLabel xml:lang="en">Unknown Data Source</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-UtilityProvider">
        <rdfs:label xml:lang="en">Utility Provider</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Organisation"/>
        <skos:definition xml:lang="en">An organisation (public or private) that processes personal data in the provision of utilities</skos:definition>
        <skos:prefLabel xml:lang="en">Utility Provider</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#dpv-WhistleblowerManagement">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFI"/>
        <rdfs:label xml:lang="en">Whistleblower Management</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#HumanResourceManagement"/>
        <skos:definition xml:lang="en">The management of whistleblower processes, systems, and information through which individuals or groups can report on negative activities such as misconduct, harms, and compliance violations</skos:definition>
        <skos:notation>C100</skos:notation>
        <skos:prefLabel xml:lang="en">Whistleblower Management</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-aiact-FacialRecognitionTechnology">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceDK"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceRO"/>
        <rdfs:label xml:lang="en">Facial Recognition Technology</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/tech#Capability"/>
        <skos:definition xml:lang="en">A biometric identification system that detects, captures, and compares facial features to identify or verify individuals in real-time or retrospectively, as defined in the EU AI Act</skos:definition>
        <skos:notation>C36</skos:notation>
        <skos:prefLabel xml:lang="en">Facial Recognition Technology</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Proposed as rename/replacement of current tech:FaceRecognition to align with EU AI Act terminology</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-DPIANotRequiredProcess">
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/at#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/cz#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/es#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/fr#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/hr#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/it#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/lv#DPIANotRequiredList"/>
        <terms:source rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/nl#DPIANotRequiredList"/>
        <rdfs:label xml:lang="en">DPIA Not Required Process</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Process"/>
        <skos:definition xml:lang="en">A personal data processing activity that does not require a DPIA according to the whitelists of processing activities published by Member State Data Protection Authorities</skos:definition>
        <skos:prefLabel xml:lang="en">DPIA Not Required Process</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The requirements for whether a DPIA is required for a specific process can be found in GDPR Art 35 and also in specific lists published by Member State Data Protection Authorities</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-DPIARequiredProcess">
        <terms:source rdf:resource="https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32016R0679"/>
        <rdfs:label xml:lang="en">DPIA Required Process</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Process"/>
        <skos:definition xml:lang="en">A personal data processing activity that requires a DPIA according to GDPR Article 35</skos:definition>
        <skos:prefLabel xml:lang="en">DPIA Required Process</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The requirements for whether a DPIA is required for a specific process can be found in GDPR Art 35 and also in specific lists published by Member State Data Protection Authorities</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-NonSystematic">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Non-Systematic</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity"/>
        <skos:definition xml:lang="en">Indication that processing does not meet the definition of systematic</skos:definition>
        <skos:notation>C29, C39, C45, C51, C50, C55, C82, C89</skos:notation>
        <skos:prefLabel xml:lang="en">Non-Systematic</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-SignificantEffect">
        <rdfs:label xml:lang="en">Significant Effect</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Impact"/>
        <skos:definition xml:lang="en">An impact that is distinguished as being significant due to having a legal impact</skos:definition>
        <skos:prefLabel xml:lang="en">Significant Effect</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The parent to legaleffect</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematic">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Systematic</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity"/>
        <skos:definition xml:lang="en">Indication that processing occurs according to a system; is pre-arranged, organised or methodical, and takes place as part of a general plan or is carried out as part of a strategy</skos:definition>
        <skos:notation>C29, C39, C45, C51, C50, C55, C82, C89</skos:notation>
        <skos:prefLabel xml:lang="en">Systematic</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Definition follows ICO UK. Proposed as subclass of eu-gdpr:Systematicity</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBG"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSI"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSK"/>
        <rdfs:label xml:lang="en">Systematicity</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#ProcessingContext"/>
        <skos:definition xml:lang="en">An indication of whether data processing is systematic, i.e. if it is organised and constitutes repeated actions performed according to a plan or method, such as for monitoring, analysis or decision-making</skos:definition>
        <skos:notation>C29, C39, C45, C51, C50, C55, C82, C89</skos:notation>
        <skos:prefLabel xml:lang="en">Systematicity</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-EducationalInstitution">
        <rdfs:label xml:lang="en">Educational Institution</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">A Educational Insitution (including but not limited to school, university etc.)</skos:definition>
        <skos:prefLabel xml:lang="en">Educational Insitution</skos:prefLabel>
        <skos:scopeNote xml:lang="en"></skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-Healthcare">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Healthcare Location</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">A place where healthcare is provided to individuals</skos:definition>
        <skos:notation>C57</skos:notation>
        <skos:prefLabel xml:lang="en">Healthcare Location</skos:prefLabel>
        <skos:scopeNote xml:lang="en"></skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-InPublicTransport">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">In Public Transport</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#PubliclyAccessibleSpace"/>
        <skos:definition xml:lang="en">Vehicles and infrastructures used for public travel, such as buses, trains, metro, and stations, where individuals are subject to monitoring or data processing</skos:definition>
        <skos:notation>C43</skos:notation>
        <skos:prefLabel xml:lang="en">In Public Transport</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-OnPublicRoad">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">On Public Road</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#PubliclyAccessibleSpace"/>
        <skos:definition xml:lang="en">Any location accessible to the general public, particularly roads and streets used by public or private transportation, where monitoring or control of individuals is conducted via processing operations such as video surveillance or traffic sensors</skos:definition>
        <skos:notation>C43</skos:notation>
        <skos:prefLabel xml:lang="en">On Public Road</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Proposed as subclass of dpv:PubliclyAccessibleSpace pending group discussion on modelling specific locations</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-PersonalSpace">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <rdfs:label xml:lang="en">Personal Space</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">Refers to private areas such as homes or personal environments, where data processing even with consent may infringe on privacy due to the sensitive nature of the setting</skos:definition>
        <skos:notation>C90</skos:notation>
        <skos:prefLabel xml:lang="en">Personal Space</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-PreSchool">
        <skos:definition xml:lang="en">A location that is a  Preschool</skos:definition>
        <skos:prefLabel xml:lang="en">PreSchool</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-Prison">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Prison</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">A place in which individuals are held due to committing a crime or awaiting trial</skos:definition>
        <skos:notation>C57</skos:notation>
        <skos:prefLabel xml:lang="en">Prison</skos:prefLabel>
        <skos:scopeNote xml:lang="en"></skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-School">
        <skos:definition xml:lang="en">A location that is a school</skos:definition>
        <skos:prefLabel xml:lang="en">School</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-SocialCare">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Socialcare Location</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">A place where social care is provided to individuals</skos:definition>
        <skos:notation>C57</skos:notation>
        <skos:prefLabel xml:lang="en">Socialcare Location</skos:prefLabel>
        <skos:scopeNote xml:lang="en"></skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-Workplace">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLV"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Workplace</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#LocationLocality"/>
        <skos:definition xml:lang="en">A professional environment or workplace</skos:definition>
        <skos:notation>C57</skos:notation>
        <skos:prefLabel xml:lang="en">Workplace</skos:prefLabel>
        <skos:scopeNote xml:lang="en"></skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#loc-WorshipLocation">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAT"/>
        <rdfs:label xml:lang="en">Worship Location</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Location"/>
        <skos:definition xml:lang="en">A religious institution such as a church or house of prayer, where monitoring or data processing may occur for security or organisational purposes</skos:definition>
        <skos:notation>C68</skos:notation>
        <skos:prefLabel xml:lang="en">Worship Location</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-AssessmentOutcome">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">Assessment Outcome</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">Personal data that captures results or conclusions from standardised assessments, such as exams, evaluations, or diagnostic tests, aimed at determining skills, knowledge, mental health, or developmental status</skos:definition>
        <skos:notation>C45</skos:notation>
        <skos:prefLabel xml:lang="en">Assessment Outcome</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-BadConduct">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Bad Conduct</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#pd-Conduct"/>
        <skos:definition xml:lang="en">Broader term than criminal offences or unlawful conduct. It can include behaviour that may not be illegal but is still considered ethically or professionally inappropriate, controversial, or reputationally damaging</skos:definition>
        <skos:notation>C9</skos:notation>
        <skos:prefLabel xml:lang="en">Bad Conduct</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-Career">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
        <rdfs:label xml:lang="en">Career</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#Professional"/>
        <skos:definition xml:lang="en">Personal data related to an individual&apos;s professional progression, roles held, promotions, or career evaluations that may impact employment opportunities</skos:definition>
        <skos:notation>C105</skos:notation>
        <skos:prefLabel xml:lang="en">Career</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-Competency">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">Competency</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">Personal data used in the systematic evaluation of an individual&apos;s overall effectiveness in applying knowledge and skills, including professional qualifications, behavioural performance, and domain-specific expertise</skos:definition>
        <skos:notation>C45</skos:notation>
        <skos:prefLabel xml:lang="en">Competency</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-Conduct">
        <rdfs:label xml:lang="en">Conduct</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">A pattern or instance of individual behaviour, particularly in relation to lawfulness, ethics, professional standards, or social expectations. Conduct can be evaluated as good or bad based on its alignment with normative, legal, or reputational frameworks</skos:definition>
        <skos:prefLabel xml:lang="en">Conduct</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The parent for bad conduct and good conduct</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-DigitalTwin">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceDK"/>
        <rdfs:label xml:lang="en">Digital Twin</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">A digital representation of a real-world person, where personal data is processed to simulate, predict, or monitor behaviour, performance, or health</skos:definition>
        <skos:notation>C84</skos:notation>
        <skos:prefLabel xml:lang="en">Digital Twin</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-ElectronicHealthCard">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Electronic Health Card</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#HealthRecord"/>
        <skos:definition xml:lang="en">A digital or physical card used to store or provide access to personal health data, as part of large-scale systematic processing for public health purposes, including integration with electronic prescription and health record systems</skos:definition>
        <skos:notation>C39</skos:notation>
        <skos:prefLabel xml:lang="en">Electronic Health Card</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-ElectronicHealthRecord">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHU"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNL"/>
        <rdfs:label xml:lang="en">Electronic Health Record</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#HealthRecord"/>
        <skos:definition xml:lang="en">A digital record of a patient&apos;s medical history, diagnoses, medications, treatment plans, and other health-related information</skos:definition>
        <skos:notation>C39</skos:notation>
        <skos:prefLabel xml:lang="en">Electronic Health Record</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-GoodConduct">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Good Conduct</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#pd-Conduct"/>
        <skos:definition xml:lang="en">Behaviour that is lawful, ethical, professional, reputation-enhancing or neutral and unlikely to cause social or professional harm</skos:definition>
        <skos:notation>C9</skos:notation>
        <skos:prefLabel xml:lang="en">Good Conduct</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-LocationDisplacement">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <rdfs:label xml:lang="en">Location Displacement</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">Personal data processed to analyse or predict a person&apos;s change in location, movement patterns, or relocation behaviours, often linked to economic or social factors</skos:definition>
        <skos:notation>C87</skos:notation>
        <skos:prefLabel xml:lang="en">Location Displacement</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-LocationRoute">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <rdfs:label xml:lang="en">Location Route</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#Location"/>
        <skos:definition xml:lang="en">Personal data representing an individual&apos;s travel path or movement behaviour, processed to predict interests, routines, or mobility patterns</skos:definition>
        <skos:notation>C61</skos:notation>
        <skos:prefLabel xml:lang="en">Location Route</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-Skill">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourcePL"/>
        <rdfs:label xml:lang="en">Skill</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">Personal data processed for the systematic assessment of an individual&apos;s capabilities or expertise, including the evaluation of specific learned abilities, aptitudes, or training outcomes</skos:definition>
        <skos:notation>C45</skos:notation>
        <skos:prefLabel xml:lang="en">Skill</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-Trustworthiness">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceNO"/>
        <rdfs:label xml:lang="en">Trustworthiness</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#External"/>
        <skos:definition xml:lang="en">Personal data processed to predict or assess an individual&apos;s reliability, integrity, or honesty, often in the context of providing services, financial products, or employment assessments</skos:definition>
        <skos:notation>C61</skos:notation>
        <skos:prefLabel xml:lang="en">Trustworthiness</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#pd-UnlawfulActivity">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceAll"/>
        <rdfs:label xml:lang="en">Unlawful Activity</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv/pd#Social"/>
        <skos:definition xml:lang="en">Unlawful activity under GDPR refers to any unlawful activity that violates laws and regulations</skos:definition>
        <skos:notation>C9</skos:notation>
        <skos:prefLabel xml:lang="en">Unlawful Activity</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ContractExclusion">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceES"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLI"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSI"/>
        <rdfs:label xml:lang="en">Contract Exclusion</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract"/>
        <skos:definition xml:lang="en">Where an individual or an organisation is denied the opportunity to enter into a contract</skos:definition>
        <skos:notation>C20</skos:notation>
        <skos:prefLabel xml:lang="en">Contract Exclusion</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ContractRefused">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHR"/>
        <rdfs:label xml:lang="en">Contract Refused</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract"/>
        <skos:definition xml:lang="en">An impact where personal data, often from third parties, is used to inform a decision to deny entry into a service contract with a natural person</skos:definition>
        <skos:notation>C52</skos:notation>
        <skos:prefLabel xml:lang="en">Contract Refused</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ContractSuspension">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceES"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceFR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceHR"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIS"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceIT"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceLI"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceSI"/>
        <rdfs:label xml:lang="en">Contract Suspension</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract"/>
        <skos:definition xml:lang="en">Where an existing contract is temporarily halted or rendered inactive, such as due to suspicion of fraud, violation of terms, or negative behavioural indicators</skos:definition>
        <skos:notation>C20</skos:notation>
        <skos:prefLabel xml:lang="en">Contract Suspension</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ContractTerminated">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceBE"/>
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceCY"/>
