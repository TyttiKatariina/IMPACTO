        <owl:versionIRI rdf:resource="https://tyttikatariina.github.io/IMPACTO/1.0"/>
        <terms:bibliographicCitation xml:lang="en">Tytti Rintamäki, Harshvardhan J. Pandit. IMPACTO: An ontology for representing Impact Assessment requirements and processes based on the GDPR and EU AI ACT.</terms:bibliographicCitation>
        <terms:contributor>Harshvardhan J. Pandit</terms:contributor>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-25</terms:created>
        <terms:creator>Tytti Rintamäki</terms:creator>
        <terms:description xml:lang="en">IMPACTO represents impact assessments, specifically the DPIA and FRIA.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-25</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-25</terms:modified>
        <terms:publisher>ADAPT Centre, Dublin City University</terms:publisher>
        <terms:source xml:lang="en"> AT, BE, BG, CY, CZ, DE, DK, EE, ES, FI, FR, GR, HR, HU, IE, IS, IT, LI, LT, LU, LV, MT, NL, NO, PL, PT, RO, SE, SI, SK</terms:source>
        <terms:source xml:lang="en">EU AI Act</terms:source>
        <terms:source xml:lang="en">GDPR</terms:source>
        <terms:title xml:lang="en">IMPACTO</terms:title>
        <rdfs:label xml:lang="en">Impact Assessment Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


