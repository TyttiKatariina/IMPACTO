        <rdfs:label xml:lang="en">Contract Terminated</rdfs:label>
        <skos:broader rdf:resource="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract"/>
        <skos:definition xml:lang="en">Where an existing contract is cancelled or terminated, such as by revoking a loan, ending a subscription, or dismissing an employee</skos:definition>
        <skos:notation>C20, C52</skos:notation>
        <skos:prefLabel xml:lang="en">Contract Terminated</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnCareer">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
