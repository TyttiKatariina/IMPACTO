        <skos:broader rdf:resource="https://w3id.org/dpv#Impact"/>
        <skos:definition xml:lang="en">Where the career of an individual is impacted</skos:definition>
        <skos:notation>C105</skos:notation>
        <skos:prefLabel xml:lang="en">Impact On Career</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract">
        <rdfs:label xml:lang="en">Impact On Contract</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Impact"/>
        <skos:definition xml:lang="en">Where there is an effect, positive or negative, on an existing contract, such as suspension, termination, or exclusion</skos:definition>
        <skos:prefLabel xml:lang="en">Impact On Contract</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Parent term for contract-related risks. Modelled as impact to align with legal effects on the contractual party</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-LegalEffect">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceGDPR"/>
        <rdfs:label xml:lang="en">Legal Effect Risk</rdfs:label>
        <skos:broader rdf:resource="https://w3id.org/dpv#Risk"/>
        <skos:definition xml:lang="en">A risk that processing results in legal effects for the data subjects</skos:definition>
        <skos:prefLabel xml:lang="en">Legal Effect Risk</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Used to indicate that a processing activity may result in effects equivalent to legal consequences for data subjects, such as denial of service or exclusion from contracts</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://tyttikatariina.github.io/IMPACTO/#risk-PropertyLoss">
        <terms:source rdf:resource="https://tyttikatariina.github.io/IMPACTO/#SourceEE"/>
