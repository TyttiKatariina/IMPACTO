<https://tyttikatariina.github.io/IMPACTO/#ServiceRelatedConsequence> rdfs:label "Service Related Consequence"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Impact> ;
                                                                      <http://www.w3.org/2004/02/skos/core#definition> "A consequence that affects an individual's or organisation's access to or participation in a service"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Service Related Consequence"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#scopeNote> "Parent term for service-related consequences"@en .


<https://tyttikatariina.github.io/IMPACTO/#ai-AutomaticObjectRecognition> rdfs:label "Automatic Object Recognition"@en ;
                                                                          <http://www.w3.org/2004/02/skos/core#definition> "The use of an AI system capable of automatic object recognition"@en ;
                                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Automatic Object Recognition"@en .


<https://tyttikatariina.github.io/IMPACTO/#ai-FacialRecognition> rdfs:label "Facial Recognition"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "The use of an AI system capable of facial recognition"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Facial Recognition"@en .


<https://tyttikatariina.github.io/IMPACTO/#ai-ObjectIsolation> rdfs:label "Object Isolation"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "The use of an AI system capable of isolating objects"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Object Isolation"@en .


<https://tyttikatariina.github.io/IMPACTO/#ai-UseOfAI> rdfs:label "Use Of AI"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "The use of an AI system in processing of personal data"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Use Of AI"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-Automated> rdfs:label "Automated"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ProcessingContext> ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Processing context indicating that automation is involved and parent concept for all automation-related processing contexts"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Automated"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-CentralisedLocation> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceDE> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceSI> ;
                                                                    rdfs:label "Centralised Location"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#LocationFixture> ;
                                                                    <http://www.w3.org/2004/02/skos/core#definition> "A physical or digital point where data is collected and aggregated from multiple sources, typically involving centralised sensors or mobile-based systems for large-scale monitoring or control"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "C62" ;
                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Centralised Location"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-ClassificationOfIndividuals> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ,
                                                                                                              <https://tyttikatariina.github.io/IMPACTO/#SourceHU> ,
                                                                                                              <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                                            rdfs:label "Classification Of Individuals"@en ;
                                                                            <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ProcessingContext> ;
                                                                            <http://www.w3.org/2004/02/skos/core#definition> "Processing that evaluates, ranks, or categorises natural persons, often based on behavioural, demographic, or personal data"@en ;
                                                                            <http://www.w3.org/2004/02/skos/core#notation> "C48" ;
                                                                            <http://www.w3.org/2004/02/skos/core#prefLabel> "Classification Of Individuals"@en ;
                                                                            <http://www.w3.org/2004/02/skos/core#scopeNote> "Phrasing follows Article 29 Data Protection Working Party and EDPB guidelines"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-HistoricResearch> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceLT> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceLU> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceLV> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourcePT> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceSK> ;
                                                                 rdfs:label "Historical Research"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ResearchAndDevelopment> ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "The processing of personal data for scientific or historical research purposes, conducted without the data subject's consent, and in conjunction with at least one of the legal criteria under the GDPR, such as being necessary for a task carried out in the public interest"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#notation> "C30" ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Historical Research"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-Inspection> rdfs:label "Inspection"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ProcessingContext> ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A processing context where personal data is used as part of an evaluative or investigative activity or purpose"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Inspection"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-LabourBrokeringService> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEE> ;
                                                                       rdfs:label "Labour Brokering Service"@en ;
                                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#HumanResourceManagement> ;
                                                                       <http://www.w3.org/2004/02/skos/core#definition> "Service that facilitates labour provision through a brokering process, including matching workers with jobs or facilitating labour based on demand"@en ;
                                                                       <http://www.w3.org/2004/02/skos/core#notation> "C105" ;
                                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Labour Brokering Service"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-Monitoring> <http://www.w3.org/2004/02/skos/core#definition> "A purpose involving the monitoring of individuals"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Monitoring"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-MonitoringIndividuals> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                                      rdfs:label "Monitoring Individuals"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ProcessingContext> ;
                                                                      <http://www.w3.org/2004/02/skos/core#definition> "Monitoring of humans (as individuals or as groups) which includes a systematic observation or surveillance of behaviour, movements, or activities"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#notation> "C5, C43, C46, C53, C55, C61, C76, C87, C97" ;
                                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Monitoring Individuals"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#scopeNote> "Proposed as addition to dpv: — differs from existing dpv:Monitor (which monitors data for criteria) by focusing specifically on monitoring of data subjects themselves"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-NonDataSubjectDataSource> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ,
                                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceCZ> ,
                                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceDE> ,
                                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceES> ,
                                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceLT> ;
                                                                         rdfs:label "Non Data Subject Data Source"@en ;
                                                                         <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#DataSource> ;
                                                                         <http://www.w3.org/2004/02/skos/core#definition> "Personal data obtained from a third party or another source rather than directly from the individual concerned, especially in cases where informing the data subject would be difficult or impossible, such as in law enforcement, research, or archival processing"@en ;
                                                                         <http://www.w3.org/2004/02/skos/core#notation> "C25" ;
                                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Non Data Subject Data Source"@en ;
                                                                         <http://www.w3.org/2004/02/skos/core#scopeNote> "Existing non-data subject sources in DPV should be moved below this concept"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-Predict> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEDPB> ;
                                                        rdfs:label "Predict"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Infer> ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "To anticipate or forecast aspects of an individual's behaviour, characteristics, or future actions"@en ;
                                                        <http://www.w3.org/2004/02/skos/core#notation> "C14, C37, C73" ;
                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Predict"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-PreventativeProtectionOfPersons> rdfs:label "Preventative Protection Of Persons"@en ;
                                                                                <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#EnforceSecurity> ;
                                                                                <http://www.w3.org/2004/02/skos/core#definition> "Processing carried out for the purpose of preventing harm or protecting individuals before an incident occurs"@en ;
                                                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Preventative Protection Of Persons"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-PreventativeProtectionOfProperty> rdfs:label "Preventative Protection Of Property"@en ;
                                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#EnforceSecurity> ;
                                                                                 <http://www.w3.org/2004/02/skos/core#definition> "Processing carried out for the purpose of preventing loss or damage to property before an incident occurs"@en ;
                                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Preventative Protection Of Property"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-PrivateUtilityProvider> rdfs:label "Private Utility Provider"@en ;
                                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#dpv-UtilityProvider> ;
                                                                       <http://www.w3.org/2004/02/skos/core#definition> "A private organisation providing utilities"@en ;
                                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Private Utility Provider"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-PublicUtilityProvider> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
