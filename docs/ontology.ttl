                                                                        <http://www.w3.org/2004/02/skos/core#notation> "C100" ;
                                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Whistleblower Management"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-aiact-FacialRecognitionTechnology> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceDK> ,
                                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceIT> ,
                                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ,
                                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceRO> ;
                                                                                 rdfs:label "Facial Recognition Technology"@en ;
                                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/tech#Capability> ;
                                                                                 <http://www.w3.org/2004/02/skos/core#definition> "A biometric identification system that detects, captures, and compares facial features to identify or verify individuals in real-time or retrospectively, as defined in the EU AI Act"@en ;
                                                                                 <http://www.w3.org/2004/02/skos/core#notation> "C36" ;
                                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Facial Recognition Technology"@en ;
                                                                                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Proposed as rename/replacement of current tech:FaceRecognition to align with EU AI Act terminology"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-DPIANotRequiredProcess> <http://purl.org/dc/terms/source> <https://w3id.org/dpv/legal/eu/gdpr/at#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/cz#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/es#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/fr#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/hr#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/it#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/lv#DPIANotRequiredList> ,
                                                                                                             <https://w3id.org/dpv/legal/eu/gdpr/nl#DPIANotRequiredList> ;
                                                                           rdfs:label "DPIA Not Required Process"@en ;
                                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Process> ;
                                                                           <http://www.w3.org/2004/02/skos/core#definition> "A personal data processing activity that does not require a DPIA according to the whitelists of processing activities published by Member State Data Protection Authorities"@en ;
                                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "DPIA Not Required Process"@en ;
                                                                           <http://www.w3.org/2004/02/skos/core#scopeNote> "The requirements for whether a DPIA is required for a specific process can be found in GDPR Art 35 and also in specific lists published by Member State Data Protection Authorities"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-DPIARequiredProcess> <http://purl.org/dc/terms/source> <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32016R0679> ;
                                                                        rdfs:label "DPIA Required Process"@en ;
                                                                        <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Process> ;
                                                                        <http://www.w3.org/2004/02/skos/core#definition> "A personal data processing activity that requires a DPIA according to GDPR Article 35"@en ;
                                                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "DPIA Required Process"@en ;
                                                                        <http://www.w3.org/2004/02/skos/core#scopeNote> "The requirements for whether a DPIA is required for a specific process can be found in GDPR Art 35 and also in specific lists published by Member State Data Protection Authorities"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-NonSystematic> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                                  rdfs:label "Non-Systematic"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity> ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "Indication that processing does not meet the definition of systematic"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "C29, C39, C45, C51, C50, C55, C82, C89" ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Non-Systematic"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-SignificantEffect> rdfs:label "Significant Effect"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Impact> ;
                                                                      <http://www.w3.org/2004/02/skos/core#definition> "An impact that is distinguished as being significant due to having a legal impact"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Significant Effect"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#scopeNote> "The parent to legaleffect"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematic> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                               rdfs:label "Systematic"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity> ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Indication that processing occurs according to a system; is pre-arranged, organised or methodical, and takes place as part of a general plan or is carried out as part of a strategy"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#notation> "C29, C39, C45, C51, C50, C55, C82, C89" ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Systematic"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "Definition follows ICO UK. Proposed as subclass of eu-gdpr:Systematicity"@en .


<https://tyttikatariina.github.io/IMPACTO/#eu-gdpr-Systematicity> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceBG> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceHU> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceSI> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceSK> ;
                                                                  rdfs:label "Systematicity"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#ProcessingContext> ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "An indication of whether data processing is systematic, i.e. if it is organised and constitutes repeated actions performed according to a plan or method, such as for monitoring, analysis or decision-making"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "C29, C39, C45, C51, C50, C55, C82, C89" ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Systematicity"@en .


