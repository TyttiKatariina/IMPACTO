                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Healthcare Location"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#scopeNote> ""@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-InPublicTransport> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                    <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                                  rdfs:label "In Public Transport"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#PubliclyAccessibleSpace> ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "Vehicles and infrastructures used for public travel, such as buses, trains, metro, and stations, where individuals are subject to monitoring or data processing"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "C43" ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "In Public Transport"@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-OnPublicRoad> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ,
                                                                                               <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                               <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                               <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                             rdfs:label "On Public Road"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#PubliclyAccessibleSpace> ;
                                                             <http://www.w3.org/2004/02/skos/core#definition> "Any location accessible to the general public, particularly roads and streets used by public or private transportation, where monitoring or control of individuals is conducted via processing operations such as video surveillance or traffic sensors"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#notation> "C43" ;
                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "On Public Road"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#scopeNote> "Proposed as subclass of dpv:PubliclyAccessibleSpace pending group discussion on modelling specific locations"@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-PersonalSpace> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ;
                                                              rdfs:label "Personal Space"@en ;
                                                              <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#LocationLocality> ;
                                                              <http://www.w3.org/2004/02/skos/core#definition> "Refers to private areas such as homes or personal environments, where data processing even with consent may infringe on privacy due to the sensitive nature of the setting"@en ;
                                                              <http://www.w3.org/2004/02/skos/core#notation> "C90" ;
                                                              <http://www.w3.org/2004/02/skos/core#prefLabel> "Personal Space"@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-PreSchool> <http://www.w3.org/2004/02/skos/core#definition> "A location that is a  Preschool"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "PreSchool"@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-Prison> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceLV> ,
                                                                                         <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ;
                                                       rdfs:label "Prison"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#LocationLocality> ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "A place in which individuals are held due to committing a crime or awaiting trial"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#notation> "C57" ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Prison"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#scopeNote> ""@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-School> <http://www.w3.org/2004/02/skos/core#definition> "A location that is a school"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "School"@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-SocialCare> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceLV> ,
                                                                                             <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ;
                                                           rdfs:label "Socialcare Location"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#LocationLocality> ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A place where social care is provided to individuals"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "C57" ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Socialcare Location"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#scopeNote> ""@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-Workplace> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceLV> ,
                                                                                            <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ;
                                                          rdfs:label "Workplace"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#LocationLocality> ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "A professional environment or workplace"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "C57" ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Workplace"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#scopeNote> ""@en .


<https://tyttikatariina.github.io/IMPACTO/#loc-WorshipLocation> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAT> ;
                                                                rdfs:label "Worship Location"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Location> ;
                                                                <http://www.w3.org/2004/02/skos/core#definition> "A religious institution such as a church or house of prayer, where monitoring or data processing may occur for security or organisational purposes"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "C68" ;
                                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Worship Location"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-AssessmentOutcome> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                                 rdfs:label "Assessment Outcome"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "Personal data that captures results or conclusions from standardised assessments, such as exams, evaluations, or diagnostic tests, aimed at determining skills, knowledge, mental health, or developmental status"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#notation> "C45" ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Assessment Outcome"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-BadConduct> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                          rdfs:label "Bad Conduct"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#pd-Conduct> ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Broader term than criminal offences or unlawful conduct. It can include behaviour that may not be illegal but is still considered ethically or professionally inappropriate, controversial, or reputationally damaging"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "C9" ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Bad Conduct"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-Career> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEE> ;
                                                      rdfs:label "Career"@en ;
                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#Professional> ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "Personal data related to an individual's professional progression, roles held, promotions, or career evaluations that may impact employment opportunities"@en ;
                                                      <http://www.w3.org/2004/02/skos/core#notation> "C105" ;
                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Career"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-Competency> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                            <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ,
                                                                                            <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                          rdfs:label "Competency"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                          <http://www.w3.org/2004/02/skos/core#definition> "Personal data used in the systematic evaluation of an individual's overall effectiveness in applying knowledge and skills, including professional qualifications, behavioural performance, and domain-specific expertise"@en ;
                                                          <http://www.w3.org/2004/02/skos/core#notation> "C45" ;
                                                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Competency"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-Conduct> rdfs:label "Conduct"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "A pattern or instance of individual behaviour, particularly in relation to lawfulness, ethics, professional standards, or social expectations. Conduct can be evaluated as good or bad based on its alignment with normative, legal, or reputational frameworks"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Conduct"@en ;
                                                       <http://www.w3.org/2004/02/skos/core#scopeNote> "The parent for bad conduct and good conduct"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-DigitalTwin> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceDK> ;
                                                           rdfs:label "Digital Twin"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A digital representation of a real-world person, where personal data is processed to simulate, predict, or monitor behaviour, performance, or health"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "C84" ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Digital Twin"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-ElectronicHealthCard> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceHU> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ;
                                                                    rdfs:label "Electronic Health Card"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#HealthRecord> ;
                                                                    <http://www.w3.org/2004/02/skos/core#definition> "A digital or physical card used to store or provide access to personal health data, as part of large-scale systematic processing for public health purposes, including integration with electronic prescription and health record systems"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "C39" ;
                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Electronic Health Card"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-ElectronicHealthRecord> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                        <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                        <https://tyttikatariina.github.io/IMPACTO/#SourceHU> ,
                                                                                                        <https://tyttikatariina.github.io/IMPACTO/#SourceNL> ;
                                                                      rdfs:label "Electronic Health Record"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#HealthRecord> ;
                                                                      <http://www.w3.org/2004/02/skos/core#definition> "A digital record of a patient's medical history, diagnoses, medications, treatment plans, and other health-related information"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#notation> "C39" ;
                                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Electronic Health Record"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-GoodConduct> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                           rdfs:label "Good Conduct"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#pd-Conduct> ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "Behaviour that is lawful, ethical, professional, reputation-enhancing or neutral and unlikely to cause social or professional harm"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#notation> "C9" ;
                                                           <http://www.w3.org/2004/02/skos/core#prefLabel> "Good Conduct"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-LocationDisplacement> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ;
                                                                    rdfs:label "Location Displacement"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                                    <http://www.w3.org/2004/02/skos/core#definition> "Personal data processed to analyse or predict a person's change in location, movement patterns, or relocation behaviours, often linked to economic or social factors"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "C87" ;
                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Location Displacement"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-LocationRoute> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEE> ,
                                                                                               <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ;
                                                             rdfs:label "Location Route"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#Location> ;
                                                             <http://www.w3.org/2004/02/skos/core#definition> "Personal data representing an individual's travel path or movement behaviour, processed to predict interests, routines, or mobility patterns"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#notation> "C61" ;
                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "Location Route"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-Skill> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                       <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ,
                                                                                       <https://tyttikatariina.github.io/IMPACTO/#SourcePL> ;
                                                     rdfs:label "Skill"@en ;
                                                     <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                     <http://www.w3.org/2004/02/skos/core#definition> "Personal data processed for the systematic assessment of an individual's capabilities or expertise, including the evaluation of specific learned abilities, aptitudes, or training outcomes"@en ;
                                                     <http://www.w3.org/2004/02/skos/core#notation> "C45" ;
                                                     <http://www.w3.org/2004/02/skos/core#prefLabel> "Skill"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-Trustworthiness> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEE> ,
                                                                                                 <https://tyttikatariina.github.io/IMPACTO/#SourceNO> ;
                                                               rdfs:label "Trustworthiness"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#External> ;
                                                               <http://www.w3.org/2004/02/skos/core#definition> "Personal data processed to predict or assess an individual's reliability, integrity, or honesty, often in the context of providing services, financial products, or employment assessments"@en ;
                                                               <http://www.w3.org/2004/02/skos/core#notation> "C61" ;
                                                               <http://www.w3.org/2004/02/skos/core#prefLabel> "Trustworthiness"@en .


<https://tyttikatariina.github.io/IMPACTO/#pd-UnlawfulActivity> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceAll> ;
                                                                rdfs:label "Unlawful Activity"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv/pd#Social> ;
                                                                <http://www.w3.org/2004/02/skos/core#definition> "Unlawful activity under GDPR refers to any unlawful activity that violates laws and regulations"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "C9" ;
                                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Unlawful Activity"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ContractExclusion> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceES> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceHR> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
