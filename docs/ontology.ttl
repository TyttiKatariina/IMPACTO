                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceSE> ,
                                                                                                     <https://tyttikatariina.github.io/IMPACTO/#SourceSI> ;
                                                                   rdfs:label "Contract Exclusion"@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract> ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "Where an individual or an organisation is denied the opportunity to enter into a contract"@en ;
                                                                   <http://www.w3.org/2004/02/skos/core#notation> "C20" ;
                                                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Contract Exclusion"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ContractRefused> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
                                                                                                   <https://tyttikatariina.github.io/IMPACTO/#SourceHR> ;
                                                                 rdfs:label "Contract Refused"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract> ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "An impact where personal data, often from third parties, is used to inform a decision to deny entry into a service contract with a natural person"@en ;
                                                                 <http://www.w3.org/2004/02/skos/core#notation> "C52" ;
                                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "Contract Refused"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ContractSuspension> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceES> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceHR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceIT> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceLI> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceSE> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceSI> ;
                                                                    rdfs:label "Contract Suspension"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract> ;
                                                                    <http://www.w3.org/2004/02/skos/core#definition> "Where an existing contract is temporarily halted or rendered inactive, such as due to suspicion of fraud, violation of terms, or negative behavioural indicators"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "C20" ;
                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Contract Suspension"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ContractTerminated> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceBE> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceCY> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceES> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceFR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceGR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceHR> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceIS> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceIT> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceLI> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceSE> ,
                                                                                                      <https://tyttikatariina.github.io/IMPACTO/#SourceSI> ;
                                                                    rdfs:label "Contract Terminated"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract> ;
                                                                    <http://www.w3.org/2004/02/skos/core#definition> "Where an existing contract is cancelled or terminated, such as by revoking a loan, ending a subscription, or dismissing an employee"@en ;
                                                                    <http://www.w3.org/2004/02/skos/core#notation> "C20, C52" ;
                                                                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Contract Terminated"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnCareer> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceEE> ;
                                                                rdfs:label "Impact On Career"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Impact> ;
                                                                <http://www.w3.org/2004/02/skos/core#definition> "Where the career of an individual is impacted"@en ;
                                                                <http://www.w3.org/2004/02/skos/core#notation> "C105" ;
                                                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Impact On Career"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-ImpactOnContract> rdfs:label "Impact On Contract"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Impact> ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "Where there is an effect, positive or negative, on an existing contract, such as suspension, termination, or exclusion"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Impact On Contract"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#scopeNote> "Parent term for contract-related risks. Modelled as impact to align with legal effects on the contractual party"@en .


<https://tyttikatariina.github.io/IMPACTO/#risk-LegalEffect> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceGDPR> ;
                                                             rdfs:label "Legal Effect Risk"@en ;
                                                             <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Risk> ;
