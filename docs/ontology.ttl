                                                                      rdfs:label "Public Utility Provider"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#broader> <https://tyttikatariina.github.io/IMPACTO/#dpv-UtilityProvider> ;
                                                                      <http://www.w3.org/2004/02/skos/core#definition> "A public organisation providing utilities"@en ;
                                                                      <http://www.w3.org/2004/02/skos/core#notation> "C23" ;
                                                                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Public Utility Provider"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-Tracking> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceLI> ,
                                                                                           <https://tyttikatariina.github.io/IMPACTO/#SourceLV> ;
                                                         rdfs:label "Tracking"@en ;
                                                         <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#Use> ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "The use of data to follow or track something across contexts"@en ;
                                                         <http://www.w3.org/2004/02/skos/core#notation> "C58" ;
                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Tracking"@en ;
                                                         <http://www.w3.org/2004/02/skos/core#scopeNote> "While generalised to enable tracking of activities and events, this also encompasses tracking of individuals across websites, apps, devices, and other forms which can constitute systematic monitoring and surveillance"@en .


<https://tyttikatariina.github.io/IMPACTO/#dpv-UnknownDataSource> <http://purl.org/dc/terms/source> <https://tyttikatariina.github.io/IMPACTO/#SourceIE> ;
                                                                  rdfs:label "Unknown Data Source"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#broader> <https://w3id.org/dpv#DataSource> ;
                                                                  <http://www.w3.org/2004/02/skos/core#definition> "The origin of personal data cannot be determined or is not known"@en ;
                                                                  <http://www.w3.org/2004/02/skos/core#notation> "C94" ;
                                                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Unknown Data Source"@en .


