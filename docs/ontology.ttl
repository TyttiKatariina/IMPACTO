<https://tyttikatariina.github.io/IMPACTO/> rdf:type owl:Ontology ;
                                             owl:versionIRI <https://tyttikatariina.github.io/IMPACTO/1.0> ;
                                             <http://purl.org/dc/terms/bibliographicCitation> "Tytti Rintamäki, Harshvardhan J. Pandit. IMPACTO: An ontology for representing Impact Assessment requirements and processes based on the GDPR and EU AI ACT."@en ;
                                             <http://purl.org/dc/terms/contributor> "Harshvardhan J. Pandit" ;
                                             <http://purl.org/dc/terms/created> "2026-05-25"^^xsd:date ;
                                             <http://purl.org/dc/terms/creator> "Tytti Rintamäki" ;
                                             <http://purl.org/dc/terms/description> "IMPACTO represents impact assessments, specifically the DPIA and FRIA."@en ;
                                             <http://purl.org/dc/terms/issued> "2026-05-25"^^xsd:date ;
                                             <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                             <http://purl.org/dc/terms/modified> "2026-05-25"^^xsd:date ;
                                             <http://purl.org/dc/terms/publisher> "ADAPT Centre, Dublin City University" ;
                                             <http://purl.org/dc/terms/source> " AT, BE, BG, CY, CZ, DE, DK, EE, ES, FI, FR, GR, HR, HU, IE, IS, IT, LI, LT, LU, LV, MT, NL, NO, PL, PT, RO, SE, SI, SK"@en ,
                                                                               "EU AI Act"@en ,
                                                                               "GDPR"@en ;
                                             <http://purl.org/dc/terms/title> "IMPACTO"@en ;
                                             rdfs:label "Impact Assessment Ontology"@en ;
                                             owl:versionInfo "1.0" .

